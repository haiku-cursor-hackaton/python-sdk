FROM python:3.11-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PORT=8080

WORKDIR /app

COPY pyproject.toml README.md ./
COPY genko ./genko
COPY examples/pantry_store.py ./pantry_store.py

RUN python -m pip install --upgrade pip \
    && python -m pip install --no-cache-dir ".[examples]"

EXPOSE 8080

CMD ["sh", "-c", "uvicorn pantry_store:app --host 0.0.0.0 --port ${PORT:-8080}"]
